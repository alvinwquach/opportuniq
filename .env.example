# =============================================================================
# OpportunIQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored; .env.example is committed and public.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required — app crashes without these)
# -----------------------------------------------------------------------------
DATABASE_URL=             # Supabase pooled Postgres connection string (port 6543)
DATABASE_URL_DIRECT=      # Direct Postgres for migrations/dev (port 5432)
DIRECT_URL=               # Drizzle migration connection (non-pooled)

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=             # Supabase project URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Supabase anon/public key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= # Supabase publishable key (same as anon key in most setups)

# -----------------------------------------------------------------------------
# OpenAI (required — powers the AI diagnosis chat)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=           # OpenAI API key for GPT-4o

# -----------------------------------------------------------------------------
# Firecrawl (required for diagnosis tools — contractor search, product search, etc.)
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=        # Firecrawl API key (100K credits/month plan)

# -----------------------------------------------------------------------------
# PostHog (required for analytics + feature flags)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=  # PostHog project API key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com  # PostHog ingestion host
POSTHOG_API_KEY=          # PostHog server-side API key (for posthog-node)

# -----------------------------------------------------------------------------
# Sentry (required for error monitoring)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=   # Sentry DSN (browser)
SENTRY_DSN=               # Sentry DSN (server)
SENTRY_AUTH_TOKEN=        # Sentry auth token for source map uploads
SENTRY_ORG=               # Sentry organization slug
SENTRY_PROJECT=           # Sentry project slug

# -----------------------------------------------------------------------------
# Google Cloud (required for voice transcription + Calendar reminders)
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS= # Path to Google Cloud service account JSON file
GOOGLE_CLIENT_ID=         # Google OAuth client ID (Gmail + Calendar)
GOOGLE_CLIENT_SECRET=     # Google OAuth client secret

# -----------------------------------------------------------------------------
# Mapbox (required for map rendering in contractor search)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN= # Mapbox public token for client-side map rendering
MAPBOX_ACCESS_TOKEN=      # Mapbox server-side access token

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
YELP_API_KEY=             # Yelp Fusion API (contractor search, 500 calls/day free)
FOURSQUARE_API_KEY=       # Foursquare Places API (contractor search fallback)
YOUTUBE_API_KEY=          # YouTube Data API (guide search, 10K units/day free)
GOOGLE_MAPS_API_KEY=      # Google Maps Geocoding API (location lookup)
RESEND_API_KEY=           # Resend email API (contractor RFQ emails)
RESEND_WEBHOOK_SECRET=    # Resend webhook signature verification

# -----------------------------------------------------------------------------
# App configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://opportuniq.app  # Canonical app URL
NEXT_PUBLIC_VIDEO_DIAGNOSIS_ENABLED=false   # Enable video diagnosis feature (true/false)
CRON_SECRET=              # Secret for Vercel cron job authentication

# -----------------------------------------------------------------------------
# E2E testing (only needed locally for Playwright tests)
# -----------------------------------------------------------------------------
TEST_USER_EMAIL=          # Test account email for Playwright E2E tests
TEST_USER_PASSWORD=       # Test account password for Playwright E2E tests

# -----------------------------------------------------------------------------
# Upstash Redis (required for rate limiting)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=     # Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=   # Upstash Redis REST token

# -----------------------------------------------------------------------------
# CI/CD — set as GitHub repo secrets, not in .env.local
# -----------------------------------------------------------------------------
# DISCORD_WEBHOOK_URL=    # Discord webhook for CI/deploy alerts
